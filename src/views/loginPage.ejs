<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập Hệ Thống Quản Lý</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* --- Reset & Base Styles --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f0f4f8 0%, #d9e2ec 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* --- Login Card Container --- */
        .login-card {
            background: #ffffff;
            width: 100%;
            max-width: 420px;
            padding: 40px 35px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(29, 53, 87, 0.08);
            transition: transform 0.3s ease;
        }

        /* --- Header --- */
        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-header h2 {
            color: #102a43;
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .login-header p {
            color: #627d98;
            font-size: 14px;
        }

        /* --- Form Elements --- */
        .form-group {
            margin-bottom: 20px;
            position: relative;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #334e68;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #bcccdc;
            border-radius: 8px;
            font-size: 15px;
            color: #102a43;
            background-color: #f0f4f8;
            outline: none;
            transition: all 0.2s ease-in-out;
        }

        /* Hiệu ứng Focus chuẩn công nghiệp */
        .form-group input:focus {
            border-color: #1273e6;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(18, 115, 230, 0.15);
        }

        /* Nút ẩn hiện mật khẩu cơ học */
        .toggle-password {
            position: absolute;
            right: 14px;
            background: none;
            border: none;
            color: #627d98;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            user-select: none;
            padding: 4px;
        }

        .toggle-password:hover {
            color: #102a43;
        }

        /* --- Error Message Box --- */
        .error-box {
            background-color: #ffe3e3;
            border-left: 4px solid #ea4335;
            color: #b71c1c;
            padding: 12px 16px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 20px;
            animation: fadeIn 0.3s ease-in-out;
        }

        /* --- Submit Button --- */
        .btn-login {
            width: 100%;
            padding: 14px;
            background-color: #1273e6;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(18, 115, 230, 0.24);
        }

        .btn-login:hover {
            background-color: #0b59b3;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(18, 115, 230, 0.32);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        /* --- Footer Links --- */
        .login-footer {
            text-align: center;
            margin-top: 25px;
            font-size: 14px;
            color: #627d98;
        }

        .login-footer a {
            color: #1273e6;
            text-decoration: none;
            font-weight: 600;
        }

        .login-footer a:hover {
            text-decoration: underline;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="login-card">
        <div class="login-header">
            <h2>Chào thầy Tuấn!</h2>
            <p>Vui lòng đăng nhập để quản lý lớp học</p>
        </div>

        <% if (locals.errorMessage) { %>
            <div class="error-box">
                <%= errorMessage %>
            </div>
            <% } %>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label for="email">Email tài khoản</label>
                        <input type="email" id="email" name="userEmail" placeholder="name@example.com"
                            value="<%= locals.oldData ? oldData.userEmail : '' %>" required />
                    </div>

                    <div class="form-group">
                        <label for="password">Mật khẩu</label>
                        <div class="input-wrapper">
                            <input type="password" id="password" name="userPassword" placeholder="••••••••" required
                                autocomplete="current-password" />
                            <button type="button" class="toggle-password" id="btnToggle">HIỆN</button>
                        </div>
                    </div>

                    <button type="submit" class="btn-login">Đăng Nhập Hệ Thống</button>
                </form>

                <div class="login-footer">
                    Chưa có tài khoản? <a href="/register">Đăng ký ngay tại đây</a>
                </div>
    </div>

    <script>
        const passwordInput = document.getElementById('password');
        const toggleBtn = document.getElementById('btnToggle');

        toggleBtn.addEventListener('click', function () {
            // Cơ chế: hoán đổi type giữa 'password' và 'text'
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleBtn.textContent = 'ẨN';
            } else {
                passwordInput.type = 'password';
                toggleBtn.textContent = 'HIỆN';
            }
        });
    </script>
</body>

</html>