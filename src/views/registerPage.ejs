<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Ký Tài Khoản Hệ Thống</title>
    <!-- Nhúng Google Fonts Inter cho chữ thanh thoát -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* --- Reset & Base Styles --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f0f4f8 0%, #d9e2ec 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* --- Register Card Container --- */
        .register-card {
            background: #ffffff;
            width: 100%;
            max-width: 420px;
            padding: 40px 35px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(29, 53, 87, 0.08);
            animation: fadeIn 0.4s ease-in-out;
        }

        /* --- Header --- */
        .register-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .register-header h2 {
            color: #102a43;
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .register-header p {
            color: #627d98;
            font-size: 14px;
        }

        /* --- Form Elements --- */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #334e68;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #bcccdc;
            border-radius: 8px;
            font-size: 15px;
            color: #102a43;
            background-color: #f0f4f8;
            outline: none;
            transition: all 0.2s ease-in-out;
        }

        /* Hiệu ứng Focus chuẩn công nghiệp */
        .form-group input:focus {
            border-color: #1273e6;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(18, 115, 230, 0.15);
        }

        /* Nút ẩn hiện mật khẩu */
        .toggle-password {
            position: absolute;
            right: 14px;
            background: none;
            border: none;
            color: #627d98;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            user-select: none;
            padding: 4px;
        }

        .toggle-password:hover {
            color: #102a43;
        }

        /* --- Error Message Box (Hứng mảng lỗi Validation) --- */
        .error-box {
            background-color: #ffe3e3;
            border-left: 4px solid #ea4335;
            color: #b71c1c;
            padding: 12px 16px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 20px;
        }

        .error-item {
            margin-bottom: 4px;
            list-style-type: none;
        }

        .error-item:last-child {
            margin-bottom: 0;
        }

        /* --- Submit Button --- */
        .btn-register {
            width: 100%;
            padding: 14px;
            background-color: #102a43;
            /* Đổi màu xanh đậm để phân biệt với nút Login */
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(16, 42, 67, 0.2);
        }

        .btn-register:hover {
            background-color: #1ed2c;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(16, 42, 67, 0.3);
        }

        .btn-register:active {
            transform: translateY(0);
        }

        /* --- Footer Links --- */
        .register-footer {
            text-align: center;
            margin-top: 25px;
            font-size: 14px;
            color: #627d98;
        }

        .register-footer a {
            color: #1273e6;
            text-decoration: none;
            font-weight: 600;
        }

        .register-footer a:hover {
            text-decoration: underline;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="register-card">
        <div class="register-header">
            <h2>Tạo Tài Khoản</h2>
            <p>Đăng ký để khởi tạo hệ thống quản lý</p>
        </div>

        <!-- Vòng lặp bóc tách danh sách lỗi Validation từ Backend gửi về -->
        <% if (locals.errors && errors.length> 0) { %>
            <div class="error-box">
                <% errors.forEach(err=> { %>
                    <li class="error-item">• <%= err.msg %>
                    </li>
                    <% }) %>
            </div>
            <% } %>

                <form action="/register" method="POST">
                    <div class="form-group">
                        <label for="email">Email đăng ký</label>
                        <!-- Giữ lại email cũ nếu lỡ gõ sai mật khẩu ngắn quá -->
                        <input type="text" id="email" name="userEmail" placeholder="Thầy Tuấn nhập email..."
                            value="<%= locals.oldData ? oldData.userEmail : '' %>" required />
                    </div>

                    <div class="form-group">
                        <label for="password">Mật khẩu (Tối thiểu 6 ký tự)</label>
                        <div class="input-wrapper">
                            <input type="password" id="password" name="userPassword"
                                placeholder="Nhập mật khẩu bảo mật..." required />
                            <button type="button" class="toggle-password" id="btnToggle">HIỆN</button>
                        </div>
                    </div>

                    <button type="submit" class="btn-register">Tạo Tài Khoản Mới</button>
                </form>

                <div class="register-footer">
                    Đã có tài khoản? <a href="/login">Đăng nhập ngay</a>
                </div>
    </div>

    <!-- Tương tác ẩn/hiện mật khẩu bằng JS cơ học giống bên trang Login -->
    <script>
        const passwordInput = document.getElementById('password');
        const toggleBtn = document.getElementById('btnToggle');

        toggleBtn.addEventListener('click', function () {
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleBtn.textContent = 'ẨN';
            } else {
                passwordInput.type = 'password';
                toggleBtn.textContent = 'HIỆN';
            }
        });
    </script>
</body>

</html>